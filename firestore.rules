rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /hackathon_timer/state {
      // Anyone can read the hackathon state (for real-time sync)
      allow read: if true;

      // Only the authenticated admin can write
      // Replace YOUR_ADMIN_UID_HERE with the UID from
      // Firebase Console → Authentication → Users
      allow write: if request.auth != null
                   && request.auth.uid == 'yDK839MNEQVJUisSzarBSpzFC7s2';
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
